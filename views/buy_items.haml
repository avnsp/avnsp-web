.buy-balance
  %span.buy-balance-label Saldo
  %span.buy-balance-amount{class: @user.balance >= 0 ? 'positive' : 'negative'}= "#{@user.balance} kr"
- @purchases.each do |n, q|
  %form.buy-item{"hx-post": @buy_url, "hx-target": "#buy-list", "hx-swap": "innerHTML", method: :post}
    %input{type: :hidden, name: :name, value: n}
    %input{type: :hidden, name: :q, value: q}
    %span.buy-item-name= n
    .buy-item-controls
      %span.buy-item-count= q
      %button.btn.btn-primary.buy-btn{type: :submit, name: :change, value: '+1', disabled: @party.date != Date.today} +
